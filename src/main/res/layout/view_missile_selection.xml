<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
              android:orientation="vertical"
              android:layout_width="fill_parent"
              android:layout_height="wrap_content"
              android:background="@drawable/detail_button"
              android:padding="@dimen/ButtonEdgePadding"
              android:layout_marginBottom="@dimen/SelectListSpacing"
              android:id="@+id/lytMain">

    <LinearLayout
        android:orientation="horizontal"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:id="@+id/lytName">

        <TextView
            android:layout_width="87dp"
            android:layout_height="wrap_content"
            android:textAppearance="?android:attr/textAppearanceMedium"
            android:text="@string/type_name"
            android:id="@+id/txtNameTitle"
            android:layout_marginRight="@dimen/SeperatorMargins"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textAppearance="?android:attr/textAppearanceMedium"
            android:text="Name"
            android:id="@+id/txtName"
            android:layout_weight="1"/>

    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <LinearLayout
            android:orientation="vertical"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginRight="@dimen/MainViewSpacing"
            android:layout_weight="1">

            <LinearLayout
                android:orientation="horizontal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:id="@+id/lytEngageRange">

                <TextView
                    android:layout_width="87dp"
                    android:layout_height="wrap_content"
                    android:textAppearance="?android:attr/textAppearanceSmall"
                    android:text="@string/range"
                    android:id="@+id/txtRangeTitle"
                    android:layout_marginRight="@dimen/SeperatorMargins"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textAppearance="?android:attr/textAppearanceSmall"
                    android:text="Range"
                    android:id="@+id/txtRange"
                    android:layout_weight="1"/>
            </LinearLayout>

            <LinearLayout
                android:orientation="horizontal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:id="@+id/lytBlastRadius">

                <TextView
                    android:layout_width="87dp"
                    android:layout_height="wrap_content"
                    android:textAppearance="?android:attr/textAppearanceSmall"
                    android:text="@string/blast_radius"
                    android:id="@+id/txtBlastRadiusTitle"
                    android:layout_marginRight="@dimen/SeperatorMargins"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textAppearance="?android:attr/textAppearanceSmall"
                    android:text="Blast Radius"
                    android:id="@+id/txtBlastRadius"
                    android:layout_weight="1"/>
            </LinearLayout>

            <LinearLayout
                android:orientation="horizontal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:id="@+id/lytMaxDamage">

                <TextView
                    android:layout_width="87dp"
                    android:layout_height="wrap_content"
                    android:textAppearance="?android:attr/textAppearanceSmall"
                    android:text="@string/max_damage"
                    android:id="@+id/txtMaxDamageTitle"
                    android:layout_marginRight="@dimen/SeperatorMargins"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textAppearance="?android:attr/textAppearanceSmall"
                    android:text="@string/max_damage"
                    android:id="@+id/txtMaxDamage"
                    android:layout_weight="1"/>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/lytEMPRadius"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/txtEMPRadiusTitle"
                    android:layout_width="87dp"
                    android:layout_height="wrap_content"
                    android:text="@string/emp_radius_title"
                    android:layout_marginRight="8dp"
                    android:textAppearance="?android:attr/textAppearanceSmall" />

                <TextView
                    android:id="@+id/txtEMPRadius"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="EMP Radius"
                    android:textAppearance="?android:attr/textAppearanceSmall" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/lytWarhead"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="horizontal"/>

            <LinearLayout
                android:orientation="horizontal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:id="@+id/lytSpeed">

                <TextView
                    android:layout_width="87dp"
                    android:layout_height="wrap_content"
                    android:textAppearance="?android:attr/textAppearanceSmall"
                    android:text="@string/speed"
                    android:id="@+id/txtSpeedTitle"
                    android:layout_marginRight="@dimen/SeperatorMargins"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textAppearance="?android:attr/textAppearanceSmall"
                    android:text="Speed"
                    android:id="@+id/txtSpeed"
                    android:layout_weight="1"/>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/lytPrepTime"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/txtPrepTimeTitle"
                    android:layout_width="87dp"
                    android:layout_height="wrap_content"
                    android:layout_marginRight="@dimen/SeperatorMargins"
                    android:text="@string/prep_time"
                    android:textAppearance="?android:attr/textAppearanceSmall" />

                <TextView
                    android:id="@+id/txtPrepTime"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Prep Time"
                    android:textAppearance="?android:attr/textAppearanceSmall" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/lytFlightTime"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/txtFlightTimeTitle"
                    android:layout_width="87dp"
                    android:layout_height="wrap_content"
                    android:layout_marginRight="@dimen/SeperatorMargins"
                    android:text="@string/flight_time"
                    android:textAppearance="?android:attr/textAppearanceSmall" />

                <TextView
                    android:id="@+id/txtFlightTime"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Flight Time"
                    android:textAppearance="?android:attr/textAppearanceSmall" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/lytDetDistance"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="horizontal"/>

        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginRight="@dimen/MainViewSpacing"
            android:textSize="@dimen/ReallyBigText"
            android:textColor="?attr/WarningColour"
            android:text=""
            android:id="@+id/txtNumber"
            android:layout_gravity="top"/>

        <LinearLayout
            android:orientation="vertical"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:layout_gravity="center">

            <ImageView
                android:id="@+id/imgStealth"
                android:layout_width="@dimen/SmallButtonSize"
                android:layout_height="@dimen/SmallButtonSize"
                android:layout_gravity="center"
                android:layout_weight="10"
                android:clickable="true"
                android:src="@drawable/button_show" />

            <ImageView
                android:layout_width="@dimen/SmallButtonSize"
                android:layout_height="@dimen/SmallButtonSize"
                android:id="@+id/imgNuclear"
                android:layout_gravity="center"
                android:clickable="true"
                android:layout_weight="10"
                android:src="@drawable/radiation_trefoil"/>

            <ImageView
                android:layout_width="@dimen/SmallButtonSize"
                android:layout_height="@dimen/SmallButtonSize"
                android:id="@+id/imgICBM"
                android:layout_gravity="center"
                android:clickable="true"
                android:layout_weight="10"
                android:src="@drawable/is_icbm"/>

            <ImageView
                android:layout_width="@dimen/SmallButtonSize"
                android:layout_height="@dimen/SmallButtonSize"
                android:id="@+id/imgTracking"
                android:layout_gravity="center"
                android:clickable="true"
                android:layout_weight="10"
                android:src="@drawable/player_targetting"/>

            <ImageView
                android:layout_width="@dimen/SmallButtonSize"
                android:layout_height="@dimen/SmallButtonSize"
                android:id="@+id/imgECM"
                android:layout_gravity="center"
                android:clickable="true"
                android:layout_weight="10"
                android:src="@drawable/ecm_missile"/>

            <ImageView
                android:layout_width="@dimen/SmallButtonSize"
                android:layout_height="@dimen/SmallButtonSize"
                android:id="@+id/imgFast"
                android:layout_gravity="center"
                android:clickable="true"
                android:layout_weight="10"

                android:src="@drawable/fast_missile"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textAppearance="?android:attr/textAppearanceLarge"
                android:text="$$$"
                android:id="@+id/txtCost"
                android:layout_weight="1"
                android:gravity="bottom"/>
        </LinearLayout>

    </LinearLayout>

</LinearLayout>