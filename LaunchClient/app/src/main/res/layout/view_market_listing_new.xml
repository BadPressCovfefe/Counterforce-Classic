<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/lytMain"
    android:layout_width="fill_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="@dimen/SelectListSpacing"
    android:background="@drawable/text_button_normal"
    android:orientation="vertical">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="horizontal">

        <LinearLayout
            android:id="@+id/lytType"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:gravity="center"
            android:orientation="horizontal">

            <ImageView
                android:id="@+id/imgType"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:layout_gravity="center"
                android:layout_weight="1"
                android:padding="@dimen/ButtonImagePadding"
                android:src="@drawable/resource_icon_steel" />

        </LinearLayout>

        <LinearLayout
            android:id="@+id/lytSpecs"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="horizontal"
            android:padding="@dimen/ButtonEdgePadding"
            android:visibility="visible">

            <LinearLayout
                android:layout_width="200dp"
                android:layout_height="match_parent"
                android:gravity="center_vertical"
                android:orientation="vertical"
                android:visibility="visible">

                <LinearLayout
                    android:id="@+id/lytDesigner"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:visibility="gone">

                    <TextView
                        android:id="@+id/txtDesignerTitle"
                        android:layout_width="72dp"
                        android:layout_height="wrap_content"
                        android:layout_marginRight="@dimen/SeperatorMargins"
                        android:text="@string/seller_title"
                        android:textAppearance="?android:attr/textAppearanceSmall" />

                    <TextView
                        android:id="@+id/txtSeller"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="BootyMaster69"
                        android:textAppearance="?android:attr/textAppearanceSmall" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/lytRange"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/txtExpiryTitle"
                        android:layout_width="72dp"
                        android:layout_height="wrap_content"
                        android:layout_marginRight="@dimen/SeperatorMargins"
                        android:text="@string/expires_in_title"
                        android:textAppearance="?android:attr/textAppearanceSmall" />

                    <TextView
                        android:id="@+id/txtExpiry"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="3Days"
                        android:textAppearance="?android:attr/textAppearanceSmall" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/lytStock"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="72dp"
                        android:layout_height="wrap_content"
                        android:layout_marginRight="@dimen/SeperatorMargins"
                        android:text="@string/stock_title"
                        android:textAppearance="?android:attr/textAppearanceSmall" />

                    <TextView
                        android:id="@+id/txtStock"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="1000000 kg"
                        android:textAppearance="?android:attr/textAppearanceSmall" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/lytPriceEach"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="72dp"
                        android:layout_height="wrap_content"
                        android:layout_marginRight="@dimen/SeperatorMargins"
                        android:text="@string/price_per_title"
                        android:textAppearance="?android:attr/textAppearanceSmall" />

                    <TextView
                        android:id="@+id/txtPriceEach"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="$0.5"
                        android:textAppearance="?android:attr/textAppearanceSmall" />
                </LinearLayout>

            </LinearLayout>

            <LinearLayout
                android:id="@+id/btnPurchase"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:padding="@dimen/ButtonEdgePadding"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/txtQuantityToPurchase"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:padding="@dimen/ButtonEdgePadding"
                    android:text="10000 kg"
                    android:layout_weight="1"
                    android:layout_gravity="center"
                    android:textAppearance="?android:attr/textAppearanceSmall" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:padding="@dimen/ButtonEdgePadding"
                    android:text="@string/purchase"
                    android:id="@+id/txtPurchase"
                    android:layout_weight="1"
                    android:layout_gravity="center"
                    android:background="@drawable/detail_button"
                    android:textAppearance="?android:attr/textAppearanceSmall" />
            </LinearLayout>

        </LinearLayout>

    </LinearLayout>

    <SeekBar
        android:id="@+id/seekQuantity"
        android:progressTint="?attr/MainUIColour"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:layout_marginLeft="@dimen/SelectListSpacing"
        android:layout_marginBottom="@dimen/SelectListSpacing"
        android:layout_marginRight="@dimen/SelectListSpacing"
        android:visibility="visible" />

</LinearLayout>