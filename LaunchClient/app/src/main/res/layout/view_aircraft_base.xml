<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="horizontal"
              android:layout_width="fill_parent"
              android:layout_height="wrap_content"
              android:layout_marginBottom="@dimen/SelectListSpacing"
              android:background="@drawable/detail_button">

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_gravity="center">

        <ImageView
            android:layout_width="@dimen/PlayerInfoIconSize"
            android:layout_height="@dimen/PlayerInfoIconSize"
            android:padding="@dimen/ButtonImagePadding"
            android:id="@+id/imgAircraftType"
            android:src="@drawable/marker_bomber"
            android:layout_margin="@dimen/ButtonEdgePadding"
            android:layout_gravity="center"/>
    </LinearLayout>

    <LinearLayout
        android:orientation="horizontal"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:gravity="center_vertical"
        android:layout_gravity="center"
        android:layout_marginTop="@dimen/MainViewSpacing"
        android:layout_marginBottom="@dimen/MainViewSpacing">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center_vertical"
            android:orientation="vertical">

            <TextView
                android:id="@+id/txtAircraftType"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Bomber"
                android:textAppearance="?android:attr/textAppearanceMedium" />

            <TextView
                android:id="@+id/txtName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_vertical"
                android:gravity="center_vertical"
                android:text="Name" />

            <LinearLayout
                android:id="@+id/lytArsenal"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="horizontal">

                <ImageView
                    android:id="@+id/imgArsenalType"
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:src="@drawable/marker_missile" />

                <TextView
                    android:id="@+id/txtArmaments"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/aircraft_armaments" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/lytArsenal2"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="horizontal">

                <ImageView
                    android:id="@+id/imgArsenalType2"
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:src="@drawable/marker_interceptor" />

                <TextView
                    android:id="@+id/txtArmaments2"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/aircraft_armaments" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/lytArsenal3"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="horizontal">

                <ImageView
                    android:id="@+id/imgArsenalType3"
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:src="@drawable/todo" />

                <TextView
                    android:id="@+id/txtArmaments3"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/aircraft_armaments" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:id="@+id/lytFuel"
                android:layout_height="match_parent"
                android:orientation="horizontal">

                <ImageView
                    android:id="@+id/imgFuel"
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:src="@drawable/icon_fuel" />

                <TextView
                    android:id="@+id/txtFuelLevel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="100%"
                    android:textColor="?attr/BadColour" />
            </LinearLayout>

            <TextView
                android:id="@+id/txtHPTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="center_vertical"
                android:gravity="center_vertical"
                android:text="HP" />

            <TextView
                android:id="@+id/txtInfantryStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Ready" />

        </LinearLayout>

        <LinearLayout
            android:id="@+id/lytControls"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:layout_marginRight="@dimen/MainViewSpacing"
            android:orientation="horizontal"
            android:visibility="visible">

            <LinearLayout
                android:id="@+id/btnRefuel"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:layout_gravity="center"
                android:layout_marginLeft="@dimen/MainViewSpacing"
                android:layout_weight="1"
                android:clickable="true"
                android:orientation="horizontal"
                android:visibility="gone">

                <ImageView
                    android:id="@+id/imageView55"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_vertical"
                    android:background="@drawable/text_button_normal"
                    android:padding="@dimen/ButtonImagePadding"
                    android:src="@drawable/todo" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/btnMove"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_marginLeft="@dimen/MainViewSpacing"
                android:layout_weight="1"
                android:clickable="true"
                android:orientation="horizontal"
                android:visibility="gone">

                <ImageView
                    android:id="@+id/imageView53"
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:layout_gravity="center_vertical"
                    android:background="@drawable/text_button_normal"
                    android:padding="@dimen/ButtonImagePadding"
                    android:src="@drawable/button_move" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/btnCapture"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_marginLeft="@dimen/MainViewSpacing"
                android:layout_weight="1"
                android:clickable="true"
                android:orientation="horizontal"
                android:visibility="gone">

                <ImageView
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:layout_gravity="center_vertical"
                    android:background="@drawable/text_button_normal"
                    android:padding="@dimen/ButtonImagePadding"
                    android:src="@drawable/todo" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/btnKick"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:layout_gravity="center"
                android:layout_marginLeft="@dimen/MainViewSpacing"
                android:layout_weight="1"
                android:clickable="true"
                android:orientation="horizontal"
                android:visibility="gone">

                <ImageView
                    android:id="@+id/imgKick"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_vertical"
                    android:background="@drawable/text_button_normal"
                    android:padding="@dimen/ButtonImagePadding"
                    android:src="@drawable/todo" />
            </LinearLayout>

        </LinearLayout>

    </LinearLayout>

</LinearLayout>