<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
              android:orientation="vertical"
              android:layout_width="fill_parent"
              android:layout_height="wrap_content"
              android:background="@drawable/detail_button"
              android:padding="@dimen/ButtonEdgePadding"
              android:layout_marginBottom="@dimen/SelectListSpacing"
              android:id="@+id/lytMain">

    <LinearLayout
        android:orientation="horizontal"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:id="@+id/lytName">

        <TextView
            android:layout_width="103dp"
            android:layout_height="wrap_content"
            android:textAppearance="?android:attr/textAppearanceMedium"
            android:text="@string/type_name"
            android:id="@+id/txtNameTitle"
            android:layout_marginRight="@dimen/SeperatorMargins"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textAppearance="?android:attr/textAppearanceMedium"
            android:text="Name"
            android:id="@+id/txtName"
            android:layout_weight="1"/>

    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <LinearLayout
            android:orientation="vertical"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginRight="@dimen/MainViewSpacing"
            android:layout_weight="1">

            <LinearLayout
                android:orientation="horizontal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:id="@+id/lytRange">

                <TextView
                    android:layout_width="103dp"
                    android:layout_height="wrap_content"
                    android:textAppearance="?android:attr/textAppearanceSmall"
                    android:text="@string/range"
                    android:id="@+id/txtRangeTitle"
                    android:layout_marginRight="@dimen/SeperatorMargins"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textAppearance="?android:attr/textAppearanceSmall"
                    android:text="Range"
                    android:id="@+id/txtRange"
                    android:layout_weight="1"/>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/lytWeight"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/txtEMPRadiusTitle"
                    android:layout_width="103dp"
                    android:layout_height="wrap_content"
                    android:text="@string/emp_radius_title"
                    android:layout_marginRight="8dp"
                    android:textAppearance="?android:attr/textAppearanceSmall" />

                <TextView
                    android:id="@+id/txtWeight"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="EMP Radius"
                    android:textAppearance="?android:attr/textAppearanceSmall" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/lytHP"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="horizontal"
                android:visibility="visible" >

                <TextView
                    android:id="@+id/txtWarheadTitle"
                    android:layout_width="103dp"
                    android:layout_height="wrap_content"
                    android:layout_marginRight="8dp"
                    android:text="@string/warhead_title"
                    android:textAppearance="?android:attr/textAppearanceSmall" />

                <TextView
                    android:id="@+id/txtHP"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="100 mt"
                    android:textAppearance="?android:attr/textAppearanceSmall" />
            </LinearLayout>

            <LinearLayout
                android:orientation="horizontal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:id="@+id/lytSpeed">

                <TextView
                    android:layout_width="103dp"
                    android:layout_height="wrap_content"
                    android:textAppearance="?android:attr/textAppearanceSmall"
                    android:text="@string/speed"
                    android:id="@+id/txtSpeedTitle"
                    android:layout_marginRight="@dimen/SeperatorMargins"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textAppearance="?android:attr/textAppearanceSmall"
                    android:text="Speed"
                    android:id="@+id/txtSpeed"
                    android:layout_weight="1"/>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/lytCEP"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/txtAccuracyTitle"
                    android:layout_width="103dp"
                    android:layout_height="wrap_content"
                    android:layout_marginRight="@dimen/SeperatorMargins"
                    android:text="@string/cep_title"
                    android:textAppearance="?android:attr/textAppearanceSmall" />

                <TextView
                    android:id="@+id/txtAccuracy"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/sort_name_accuracy"
                    android:textAppearance="?android:attr/textAppearanceSmall" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/lytFlightTime"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/txtFlightTimeTitle"
                    android:layout_width="103dp"
                    android:layout_height="wrap_content"
                    android:layout_marginRight="@dimen/SeperatorMargins"
                    android:text="@string/flight_time"
                    android:textAppearance="?android:attr/textAppearanceSmall" />

                <TextView
                    android:id="@+id/txtFlightTime"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Flight Time"
                    android:textAppearance="?android:attr/textAppearanceSmall" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/lytDetDistance"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="horizontal"/>

        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginRight="@dimen/MainViewSpacing"
            android:textSize="@dimen/ReallyBigText"
            android:textColor="?attr/WarningColour"
            android:text=""
            android:id="@+id/txtNumber"
            android:layout_gravity="top"/>

        <LinearLayout
            android:orientation="vertical"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:layout_gravity="center">

            <ImageView
                android:id="@+id/imgStealth"
                android:layout_width="@dimen/SmallButtonSize"
                android:layout_height="@dimen/SmallButtonSize"
                android:layout_gravity="center"
                android:layout_weight="10"
                android:clickable="true"
                android:src="@drawable/button_show" />

            <ImageView
                android:layout_width="@dimen/SmallButtonSize"
                android:layout_height="@dimen/SmallButtonSize"
                android:id="@+id/imgNuclear"
                android:layout_gravity="center"
                android:clickable="true"
                android:layout_weight="10"
                android:src="@drawable/radiation_trefoil"/>

            <ImageView
                android:layout_width="@dimen/SmallButtonSize"
                android:layout_height="@dimen/SmallButtonSize"
                android:id="@+id/imgFast"
                android:layout_gravity="center"
                android:clickable="true"
                android:layout_weight="10"
                android:src="@drawable/icon_fast"/>

            <ImageView
                android:id="@+id/imgSonobuoy"
                android:layout_width="@dimen/SmallButtonSize"
                android:layout_height="@dimen/SmallButtonSize"
                android:layout_gravity="center"
                android:layout_weight="10"
                android:clickable="true"
                android:src="@drawable/icon_sonar" />

            <ImageView
                android:layout_width="@dimen/SmallButtonSize"
                android:layout_height="@dimen/SmallButtonSize"
                android:id="@+id/imgICBM"
                android:layout_gravity="center"
                android:clickable="true"
                android:layout_weight="10"
                android:src="@drawable/is_icbm"/>

            <ImageView
                android:layout_width="@dimen/SmallButtonSize"
                android:layout_height="@dimen/SmallButtonSize"
                android:id="@+id/imgTracking"
                android:layout_gravity="center"
                android:clickable="true"
                android:layout_weight="10"
                android:src="@drawable/player_targetting"/>

            <ImageView
                android:layout_width="@dimen/SmallButtonSize"
                android:layout_height="@dimen/SmallButtonSize"
                android:id="@+id/imgECM"
                android:layout_gravity="center"
                android:clickable="true"
                android:layout_weight="10"
                android:src="@drawable/ecm_missile"/>

            <ImageView
                android:id="@+id/imgAntiShip"
                android:layout_width="@dimen/SmallButtonSize"
                android:layout_height="@dimen/SmallButtonSize"
                android:layout_gravity="center"
                android:layout_weight="10"
                android:clickable="true"
                android:src="@drawable/icon_antiship" />

            <ImageView
                android:id="@+id/imgAntiSubmarine"
                android:layout_width="@dimen/SmallButtonSize"
                android:layout_height="@dimen/SmallButtonSize"
                android:layout_gravity="center"
                android:layout_weight="10"
                android:clickable="true"
                android:src="@drawable/icon_antisubmarine" />

        </LinearLayout>

    </LinearLayout>

</LinearLayout>