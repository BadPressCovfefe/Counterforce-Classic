<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/lytMain"
    android:layout_width="fill_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="@dimen/SelectListSpacing"
    android:orientation="vertical">

    <LinearLayout
        android:id="@+id/lytType"
        android:layout_width="fill_parent"
        android:layout_height="@dimen/ButtonHeight"
        android:background="@drawable/text_button_normal"
        android:gravity="center"
        android:orientation="horizontal"
        android:padding="@dimen/ButtonEdgePadding">

        <TextView
            android:id="@+id/txtListing"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="@dimen/ButtonEdgePadding"
            android:layout_weight="1"
            android:text="100000 Metal"
            android:textAppearance="?android:attr/textAppearanceMedium" />

        <ImageView
            android:id="@+id/imgType"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:layout_gravity="center"
            android:layout_weight="1"
            android:clickable="true"
            android:padding="@dimen/ButtonImagePadding"
            android:src="@drawable/resource_icon_steel" />

        <ImageView
            android:id="@+id/imgExpandContract"
            android:layout_width="@dimen/SmallButtonSize"
            android:layout_height="@dimen/SmallButtonSize"
            android:layout_gravity="center"
            android:layout_marginRight="@dimen/SelectListSpacing"
            android:layout_weight="0"
            android:clickable="true"
            android:padding="@dimen/SelectListSpacing"
            android:src="@drawable/button_contract" />

    </LinearLayout>

    <LinearLayout
        android:id="@+id/lytSpecs"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="@dimen/SelectListSpacing"
        android:background="@drawable/detail_button"
        android:orientation="vertical"
        android:padding="@dimen/ButtonEdgePadding"
        android:visibility="visible">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginRight="@dimen/MainViewSpacing"
                android:layout_weight="1"
                android:orientation="vertical">

                <LinearLayout
                    android:id="@+id/lytDesigner"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/txtDesignerTitle"
                        android:layout_width="103dp"
                        android:layout_height="wrap_content"
                        android:layout_marginRight="@dimen/SeperatorMargins"
                        android:text="@string/seller_title"
                        android:textAppearance="?android:attr/textAppearanceSmall" />

                    <TextView
                        android:id="@+id/txtSeller"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="BootyMaster69"
                        android:textAppearance="?android:attr/textAppearanceSmall" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/lytRange"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/txtExpiryTitle"
                        android:layout_width="103dp"
                        android:layout_height="wrap_content"
                        android:layout_marginRight="@dimen/SeperatorMargins"
                        android:text="@string/expires_in_title"
                        android:textAppearance="?android:attr/textAppearanceSmall" />

                    <TextView
                        android:id="@+id/txtExpiry"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="3Days"
                        android:textAppearance="?android:attr/textAppearanceSmall" />
                </LinearLayout>

            </LinearLayout>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:layout_gravity="center"
                android:layout_marginRight="@dimen/MainViewSpacing"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/txtCost"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:layout_weight="1"
                    android:gravity="bottom"
                    android:text="$500000"
                    android:textAppearance="?android:attr/textAppearanceLarge" />
            </LinearLayout>

        </LinearLayout>

        <LinearLayout
            android:id="@+id/btnPurchase"
            android:layout_width="match_parent"
            android:layout_height="@dimen/ButtonHeight"
            android:layout_marginLeft="@dimen/MainViewSideMargin"
            android:layout_marginTop="@dimen/MainViewSpacing"
            android:layout_marginRight="@dimen/MainViewSideMargin"
            android:layout_marginBottom="@dimen/MainViewSpacing"
            android:background="@drawable/detail_button"
            android:gravity="center"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/txtDesignNew"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginLeft="@dimen/MainViewSpacing"
                android:text="@string/purchase"
                android:textAppearance="?android:attr/textAppearanceMedium" />

        </LinearLayout>

    </LinearLayout>

</LinearLayout>