<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
              android:orientation="vertical"
              android:layout_width="match_parent"
              android:layout_height="wrap_content">

    <LinearLayout
        android:id="@+id/btnUpgradeAircraftSlots"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:layout_marginLeft="@dimen/MainViewSideMargin"
        android:layout_marginRight="@dimen/MainViewSideMargin"
        android:background="@drawable/text_button_normal"
        android:clickable="true"
        android:orientation="horizontal">

        <ImageView
            android:id="@+id/imageView5"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:padding="@dimen/ButtonImagePadding"
            android:src="@drawable/upgrade_aircraft_slots" />

        <TextView
            android:id="@+id/txtAircraftSlotUpgrade"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_vertical"
            android:layout_margin="@dimen/ButtonInset"
            android:layout_weight="0"
            android:text="@string/upgrade"
            android:textAppearance="?android:attr/textAppearanceSmall" />

        <LinearLayout
            android:id="@+id/lytMore"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="center_vertical"
            android:layout_weight="1"
            android:orientation="vertical"></LinearLayout>

        <TextView
            android:id="@+id/txtAircraftSlotUpgradeCost"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_vertical"
            android:layout_margin="@dimen/ButtonInset"
            android:layout_weight="0"
            android:text="£yay"
            android:textAppearance="?android:attr/textAppearanceLarge" />

    </LinearLayout>

    <LinearLayout
        android:id="@+id/btnPurchaseAircraft"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginLeft="@dimen/MainViewSideMargin"
        android:layout_marginTop="@dimen/MainViewSpacing"
        android:layout_marginRight="@dimen/MainViewSideMargin"
        android:gravity="center"
        android:background="@drawable/text_button_normal"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/txtPurchaseAircraft"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/ButtonInset"
            android:layout_marginBottom="@dimen/ButtonInset"

            android:text="@string/purchase_aircraft"
            android:textAppearance="?android:attr/textAppearanceMedium" />

        <ImageView
            android:id="@+id/imageView7"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="@dimen/MainViewSpacing"
            android:layout_marginTop="@dimen/ButtonImagePadding"
            android:layout_marginBottom="@dimen/ButtonImagePadding"
            android:src="@drawable/button_add" />

    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginLeft="@dimen/MainViewSideMargin"
        android:layout_marginTop="@dimen/MainViewSpacing"
        android:layout_marginRight="@dimen/MainViewSideMargin"
        android:orientation="vertical">

        <TextView
            android:id="@+id/txtAirbaseSlots"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/airbase_slots"
            android:textAppearance="?android:attr/textAppearanceMedium"
            android:textColor="?attr/GoodColour" />

    </LinearLayout>

    <View
        android:id="@+id/view3"
        android:layout_width="match_parent"
        android:layout_height="@dimen/SeparatorThickness"
        android:layout_marginTop="@dimen/SeperatorMargins"
        android:layout_marginBottom="@dimen/SeperatorMargins"
        android:background="?attr/ButtonEdgeColour" />

    <LinearLayout
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/MainViewSpacing"
        android:id="@+id/lytAircraftSlots"
        android:layout_marginLeft="@dimen/MainViewSideMargin"
        android:layout_marginRight="@dimen/MainViewSideMargin"
        android:layout_marginBottom="@dimen/MainViewSpacing">

    </LinearLayout>

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginRight="@dimen/MainViewSideMargin"
        android:layout_marginLeft="@dimen/MainViewSideMargin"
        android:layout_marginBottom="@dimen/MainViewSpacing"
        android:orientation="vertical">

        <TextView
            android:id="@+id/txtAirbaseDescription"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/airbase_description"
            android:textColor="?attr/InfoColour"
            android:textAppearance="?android:attr/textAppearanceMedium" />

    </LinearLayout>

</LinearLayout>