<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
              android:orientation="vertical"
              android:layout_width="fill_parent"
              android:layout_height="wrap_content"
              android:background="@drawable/text_button_normal">

    <ImageView
        android:id="@+id/imgOnOff"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:layout_marginTop="@dimen/MainViewSideMargin"
        android:src="@drawable/button_diplomacy"
        android:visibility="visible" />

    <LinearLayout
        android:id="@+id/lytContent"
        android:orientation="vertical"
        android:gravity="center"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginLeft="@dimen/MainViewSideMargin"
        android:layout_marginRight="@dimen/MainViewSideMargin">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/alliance_adjust_tax"
            android:id="@+id/txtAdjustTaxRate"
            android:padding="@dimen/MainViewSpacing"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:orientation="horizontal">

            <ImageView
                android:id="@+id/btnDecreaseTax"
                android:layout_width="@dimen/MainViewBottomMargin"
                android:layout_height="@dimen/MainViewBottomMargin"
                android:background="@drawable/detail_button"
                android:padding="@dimen/MainViewSpacing"
                android:src="@drawable/button_minus" />

            <TextView
                android:id="@+id/txtCurrentTaxRate"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:padding="@dimen/MainViewSpacing"
                android:text="69%"
                android:textAppearance="?android:attr/textAppearanceMedium" />

            <ImageView
                android:id="@+id/btnIncreaseTax"
                android:layout_width="@dimen/MainViewBottomMargin"
                android:layout_height="@dimen/MainViewBottomMargin"
                android:background="@drawable/detail_button"
                android:padding="@dimen/MainViewSpacing"
                android:src="@drawable/button_plus" />
        </LinearLayout>

    </LinearLayout>

    <LinearLayout
        android:orientation="horizontal"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/MainViewSideMargin"
        android:layout_marginBottom="@dimen/MainViewSideMargin">

        <TextView
            android:id="@+id/btnOk"
            android:layout_width="fill_parent"
            android:layout_height="@dimen/ButtonHeight"
            android:layout_gravity="center_horizontal"
            android:layout_marginLeft="@dimen/MainViewSideMargin"
            android:layout_marginRight="@dimen/MainViewSideMargin"
            android:layout_weight="1"
            android:background="@drawable/text_button_normal"
            android:clickable="true"
            android:gravity="center"
            android:text="@string/dialog_ok"
            android:visibility="visible" />

        <TextView
            android:id="@+id/btnCancel"
            android:layout_width="fill_parent"
            android:layout_height="@dimen/ButtonHeight"
            android:layout_gravity="center_horizontal"
            android:layout_marginLeft="@dimen/MainViewSideMargin"
            android:layout_marginRight="@dimen/MainViewSideMargin"
            android:layout_weight="1"
            android:background="@drawable/text_button_normal"
            android:clickable="true"
            android:gravity="center"
            android:text="@string/cancel"
            android:visibility="visible" />

    </LinearLayout>

</LinearLayout>