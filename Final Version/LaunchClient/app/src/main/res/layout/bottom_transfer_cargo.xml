<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
             xmlns:tools="http://schemas.android.com/tools"
             android:layout_width="match_parent"
             android:layout_height="match_parent"
             android:foreground="@drawable/view_frame">

    <ScrollView
        android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="?attr/PanelTransparency"
                android:fadeScrollbars="false"
                android:scrollbarThumbVertical="?attr/ScrollBarColour">

        <LinearLayout
            android:orientation="vertical"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            >

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textAppearance="?android:attr/textAppearanceLarge"
                android:text="@string/title_transfer_cargo"
                android:id="@+id/txtTransferCargoTitle"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="@dimen/MainViewSpacing"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textAppearance="?android:attr/textAppearanceMedium"
                android:text="@string/hint_load_cargo"
                android:id="@+id/txtTransferCargoHint"
                android:textColor="?attr/InfoColour"
                android:layout_marginTop="@dimen/MainViewSpacing"
                android:layout_marginLeft="@dimen/MainViewSideMargin"
                android:layout_marginRight="@dimen/MainViewSideMargin"/>

            <LinearLayout
                android:id="@+id/lytContents"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_marginLeft="@dimen/MainViewSideMargin"
                android:layout_marginTop="@dimen/MainViewSpacing"
                android:layout_marginRight="@dimen/MainViewSideMargin"
                android:orientation="vertical"
                android:visibility="gone">

            </LinearLayout>

            <TextView
                android:id="@+id/txtSelectReciever"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/MainViewSpacing"
                android:layout_marginLeft="@dimen/MainViewSideMargin"
                android:text="@string/select_hauler"
                android:textColor="?attr/BadColour"
                android:visibility="visible" />

            <LinearLayout
                android:orientation="horizontal"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_marginTop="@dimen/MainViewSpacing"
                android:id="@+id/lytMoveControls"
                android:layout_marginLeft="@dimen/MainViewSideMargin"
                android:layout_marginRight="@dimen/MainViewSideMargin">

                <LinearLayout
                    android:orientation="horizontal"
                    android:layout_width="fill_parent"
                    android:layout_height="@dimen/ButtonHeight"
                    android:id="@+id/btnTransferCargo"
                    android:clickable="true"
                    android:layout_weight="1"
                    android:layout_marginRight="@dimen/HorizontalSpacing"
                    android:background="@drawable/text_button_normal">

                    <ImageView
                        android:layout_width="wrap_content"
                        android:layout_height="@dimen/ButtonHeight"
                        android:id="@+id/imgTransferCargo"
                        android:src="@drawable/button_load_cargo"
                        android:padding="@dimen/ButtonImagePadding"
                        android:layout_weight="1"/>
                </LinearLayout>

                <LinearLayout
                    android:orientation="horizontal"
                    android:layout_width="fill_parent"
                    android:layout_height="@dimen/ButtonHeight"
                    android:id="@+id/btnDropCargo"
                    android:clickable="true"
                    android:layout_weight="1"
                    android:background="@drawable/text_button_normal">

                    <ImageView
                        android:layout_width="wrap_content"
                        android:layout_height="@dimen/ButtonHeight"
                        android:id="@+id/imgDropCargo"
                        android:src="@drawable/button_drop_cargo"
                        android:padding="@dimen/ButtonImagePadding"
                        android:layout_weight="1"/>
                </LinearLayout>

                <LinearLayout
                    android:orientation="horizontal"
                    android:layout_width="fill_parent"
                    android:layout_height="wrap_content"
                    android:id="@+id/btnCancel"
                    android:clickable="true"
                    android:layout_marginLeft="@dimen/HorizontalSpacing"
                    android:layout_weight="1"
                    android:background="@drawable/text_button_normal">

                    <ImageView
                        android:id="@+id/imageView9"
                        android:layout_width="wrap_content"
                        android:layout_height="@dimen/ButtonHeight"
                        android:layout_weight="1"
                        android:padding="@dimen/ButtonImagePadding"
                        android:src="@drawable/button_cancel" />
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/lytIncrement"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_marginTop="@dimen/MainViewSpacing"
                android:layout_marginLeft="@dimen/MainViewSideMargin"
                android:layout_marginRight="@dimen/MainViewSideMargin"
                android:layout_weight="1"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="89dp"
                    android:layout_height="wrap_content"
                    android:textAppearance="?android:attr/textAppearanceMedium"
                    android:text="@string/quantity_title"
                    android:layout_marginRight="@dimen/MainViewSpacing"
                    android:layout_gravity="center"/>

                <EditText
                    android:id="@+id/txtQuantityEdit"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/ButtonHeight"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:padding="@dimen/ButtonImagePadding"
                    android:background="@drawable/text_button_normal"
                    android:hint="@string/enter_quantity"
                    android:inputType="number"
                    android:maxLength="9" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/lytSalePrice"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginLeft="@dimen/MainViewSideMargin"
                android:layout_marginTop="@dimen/MainViewSpacing"
                android:layout_marginRight="@dimen/MainViewSideMargin"
                android:layout_weight="1"
                android:orientation="horizontal"
                android:visibility="gone">

                <TextView
                    android:layout_width="89dp"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:layout_marginRight="@dimen/MainViewSpacing"
                    android:text="@string/price_per_title"
                    android:textAppearance="?android:attr/textAppearanceMedium" />

                <EditText
                    android:id="@+id/txtPriceEach"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/ButtonHeight"
                    android:layout_weight="1"
                    android:background="@drawable/text_button_normal"
                    android:gravity="center"
                    android:hint="@string/enter_price"
                    android:inputType="numberDecimal"
                    android:maxLength="9"
                    android:padding="@dimen/ButtonImagePadding" />

            </LinearLayout>

            <LinearLayout
                android:id="@+id/lytTotalPrice"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginLeft="@dimen/MainViewSideMargin"
                android:layout_marginTop="@dimen/MainViewSpacing"
                android:layout_marginRight="@dimen/MainViewSideMargin"
                android:layout_weight="1"
                android:orientation="horizontal"
                android:visibility="gone">

                <TextView
                    android:layout_width="89dp"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:layout_marginRight="@dimen/MainViewSpacing"
                    android:text="@string/total_title"
                    android:textAppearance="?android:attr/textAppearanceMedium" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/ButtonHeight"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/txtTotalPrice"
                        android:layout_width="wrap_content"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:text="$100000"
                        android:textAppearance="?android:attr/textAppearanceLarge" />
                </LinearLayout>

            </LinearLayout>

        </LinearLayout>
    </ScrollView>

</FrameLayout>