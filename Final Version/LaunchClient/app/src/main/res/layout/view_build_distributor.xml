<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fadeScrollbars="false"
        android:background="?attr/PanelTransparency"
        android:scrollbarThumbVertical="?attr/ScrollBarColour">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical" >

            <TextView
                android:id="@+id/txtDistributors"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_marginTop="@dimen/ButtonInset"
                android:layout_marginBottom="@dimen/ButtonInset"
                android:gravity="center"
                android:text="@string/distributors"
                android:textAppearance="?android:attr/textAppearanceMedium" />

            <ImageView
                android:id="@+id/imgModeControl"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:src="@drawable/build_distributor"
                android:visibility="visible" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginLeft="@dimen/MainViewSideMargin"
                    android:layout_marginTop="@dimen/MainViewSpacing"
                    android:layout_marginRight="@dimen/MainViewSideMargin"
                    android:background="?attr/TextViewBackgroundColour"
                    android:gravity="center"
                    android:text="@string/distributors_choose_resource"
                    android:textColor="?attr/InfoColour"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginLeft="@dimen/MainViewSideMargin"
                    android:layout_marginTop="@dimen/MainViewSpacing"
                    android:layout_marginRight="@dimen/MainViewSideMargin"
                    android:background="?attr/TextViewBackgroundColour"
                    android:gravity="center"
                    android:text="@string/resource_title_iron"
                    android:textColor="?attr/InfoColour"
                    android:textStyle="bold" />

                <com.apps.fast.launch.views.PurchaseButton
                    android:id="@+id/btnIron"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginLeft="@dimen/MainViewSideMargin"
                    android:layout_marginTop="@dimen/MainViewSpacing"
                    android:layout_marginRight="@dimen/MainViewSideMargin"
                    android:background="?attr/TextViewBackgroundColour"
                    android:gravity="center"
                    android:text="@string/resource_title_coal"
                    android:textColor="?attr/InfoColour"
                    android:textStyle="bold" />

                <com.apps.fast.launch.views.PurchaseButton
                    android:id="@+id/btnCoal"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginLeft="@dimen/MainViewSideMargin"
                    android:layout_marginTop="@dimen/MainViewSpacing"
                    android:layout_marginRight="@dimen/MainViewSideMargin"
                    android:background="?attr/TextViewBackgroundColour"
                    android:gravity="center"
                    android:text="@string/resource_title_oil"
                    android:textColor="?attr/InfoColour"
                    android:textStyle="bold" />

                <com.apps.fast.launch.views.PurchaseButton
                    android:id="@+id/btnOil"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginLeft="@dimen/MainViewSideMargin"
                    android:layout_marginTop="@dimen/MainViewSpacing"
                    android:layout_marginRight="@dimen/MainViewSideMargin"
                    android:background="?attr/TextViewBackgroundColour"
                    android:gravity="center"
                    android:text="@string/resource_title_crops"
                    android:textColor="?attr/InfoColour"
                    android:textStyle="bold" />

                <com.apps.fast.launch.views.PurchaseButton
                    android:id="@+id/btnCrops"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginLeft="@dimen/MainViewSideMargin"
                    android:layout_marginTop="@dimen/MainViewSpacing"
                    android:layout_marginRight="@dimen/MainViewSideMargin"
                    android:background="?attr/TextViewBackgroundColour"
                    android:gravity="center"
                    android:text="@string/resource_title_uranium"
                    android:textColor="?attr/InfoColour"
                    android:textStyle="bold" />

                <com.apps.fast.launch.views.PurchaseButton
                    android:id="@+id/btnUranium"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginLeft="@dimen/MainViewSideMargin"
                    android:layout_marginTop="@dimen/MainViewSpacing"
                    android:layout_marginRight="@dimen/MainViewSideMargin"
                    android:background="?attr/TextViewBackgroundColour"
                    android:gravity="center"
                    android:text="@string/resource_title_electricity"
                    android:textColor="?attr/InfoColour"
                    android:textStyle="bold" />

                <com.apps.fast.launch.views.PurchaseButton
                    android:id="@+id/btnElectricity"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginLeft="@dimen/MainViewSideMargin"
                    android:layout_marginTop="@dimen/MainViewSpacing"
                    android:layout_marginRight="@dimen/MainViewSideMargin"
                    android:background="?attr/TextViewBackgroundColour"
                    android:gravity="center"
                    android:text="@string/resource_title_stone"
                    android:textColor="?attr/InfoColour"
                    android:textStyle="bold" />

                <com.apps.fast.launch.views.PurchaseButton
                    android:id="@+id/btnConcrete"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginLeft="@dimen/MainViewSideMargin"
                    android:layout_marginTop="@dimen/MainViewSpacing"
                    android:layout_marginRight="@dimen/MainViewSideMargin"
                    android:background="?attr/TextViewBackgroundColour"
                    android:gravity="center"
                    android:text="@string/resource_title_lumber"
                    android:textColor="?attr/InfoColour"
                    android:textStyle="bold" />

                <com.apps.fast.launch.views.PurchaseButton
                    android:id="@+id/btnLumber"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginLeft="@dimen/MainViewSideMargin"
                    android:layout_marginTop="@dimen/MainViewSpacing"
                    android:layout_marginRight="@dimen/MainViewSideMargin"
                    android:background="?attr/TextViewBackgroundColour"
                    android:gravity="center"
                    android:text="@string/resource_title_food"
                    android:textColor="?attr/InfoColour"
                    android:textStyle="bold" />

                <com.apps.fast.launch.views.PurchaseButton
                    android:id="@+id/btnFood"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginLeft="@dimen/MainViewSideMargin"
                    android:layout_marginTop="@dimen/MainViewSpacing"
                    android:layout_marginRight="@dimen/MainViewSideMargin"
                    android:background="?attr/TextViewBackgroundColour"
                    android:gravity="center"
                    android:text="@string/resource_title_fuel"
                    android:textColor="?attr/InfoColour"
                    android:textStyle="bold" />

                <com.apps.fast.launch.views.PurchaseButton
                    android:id="@+id/btnFuel"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginLeft="@dimen/MainViewSideMargin"
                    android:layout_marginTop="@dimen/MainViewSpacing"
                    android:layout_marginRight="@dimen/MainViewSideMargin"
                    android:background="?attr/TextViewBackgroundColour"
                    android:gravity="center"
                    android:text="@string/resource_title_steel"
                    android:textColor="?attr/InfoColour"
                    android:textStyle="bold" />

                <com.apps.fast.launch.views.PurchaseButton
                    android:id="@+id/btnSteel"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginLeft="@dimen/MainViewSideMargin"
                    android:layout_marginTop="@dimen/MainViewSpacing"
                    android:layout_marginRight="@dimen/MainViewSideMargin"
                    android:background="?attr/TextViewBackgroundColour"
                    android:gravity="center"
                    android:text="@string/resource_title_construction_supplies"
                    android:textColor="?attr/InfoColour"
                    android:textStyle="bold" />

                <com.apps.fast.launch.views.PurchaseButton
                    android:id="@+id/btnConstructionSupplies"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginLeft="@dimen/MainViewSideMargin"
                    android:layout_marginTop="@dimen/MainViewSpacing"
                    android:layout_marginRight="@dimen/MainViewSideMargin"
                    android:background="?attr/TextViewBackgroundColour"
                    android:gravity="center"
                    android:text="@string/resource_title_machinery"
                    android:textColor="?attr/InfoColour"
                    android:textStyle="bold" />

                <com.apps.fast.launch.views.PurchaseButton
                    android:id="@+id/btnMachinery"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginLeft="@dimen/MainViewSideMargin"
                    android:layout_marginTop="@dimen/MainViewSpacing"
                    android:layout_marginRight="@dimen/MainViewSideMargin"
                    android:background="?attr/TextViewBackgroundColour"
                    android:gravity="center"
                    android:text="@string/resource_title_electronics"
                    android:textColor="?attr/InfoColour"
                    android:textStyle="bold" />

                <com.apps.fast.launch.views.PurchaseButton
                    android:id="@+id/btnElectronics"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginLeft="@dimen/MainViewSideMargin"
                    android:layout_marginTop="@dimen/MainViewSpacing"
                    android:layout_marginRight="@dimen/MainViewSideMargin"
                    android:background="?attr/TextViewBackgroundColour"
                    android:gravity="center"
                    android:text="@string/resource_title_medicine"
                    android:textColor="?attr/InfoColour"
                    android:textStyle="bold" />

                <com.apps.fast.launch.views.PurchaseButton
                    android:id="@+id/btnMedicine"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginLeft="@dimen/MainViewSideMargin"
                    android:layout_marginTop="@dimen/MainViewSpacing"
                    android:layout_marginRight="@dimen/MainViewSideMargin"
                    android:background="?attr/TextViewBackgroundColour"
                    android:gravity="center"
                    android:text="@string/resource_title_enriched_uranium"
                    android:textColor="?attr/InfoColour"
                    android:textStyle="bold" />

                <com.apps.fast.launch.views.PurchaseButton
                    android:id="@+id/btnFissile"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content" />

            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/MainViewSideMargin"
                android:layout_marginBottom="@dimen/MainViewSideMargin"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/btnCancel"
                    android:layout_width="fill_parent"
                    android:layout_height="@dimen/ButtonHeight"
                    android:layout_gravity="center_horizontal"
                    android:layout_marginLeft="@dimen/MainViewSideMargin"
                    android:layout_marginRight="@dimen/MainViewSideMargin"
                    android:layout_weight="1"
                    android:background="@drawable/text_button_normal"
                    android:clickable="true"
                    android:gravity="center"
                    android:text="@string/cancel"
                    android:visibility="visible" />

            </LinearLayout>
        </LinearLayout>
    </ScrollView>