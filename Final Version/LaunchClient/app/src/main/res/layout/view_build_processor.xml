<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fadeScrollbars="false"
        android:background="?attr/PanelTransparency"
        android:scrollbarThumbVertical="?attr/ScrollBarColour">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical" >

            <TextView
                android:id="@+id/txtProcessors"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_marginTop="@dimen/ButtonInset"
                android:layout_marginBottom="@dimen/ButtonInset"
                android:gravity="center"
                android:text="@string/processors"
                android:textAppearance="?android:attr/textAppearanceMedium" />

            <ImageView
                android:id="@+id/imgModeControl"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:src="@drawable/build_processor"
                android:visibility="visible" />

            <LinearLayout
                android:id="@+id/lytContent"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/txtGranary"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:layout_marginTop="@dimen/ButtonInset"
                    android:layout_marginBottom="@dimen/ButtonInset"
                    android:gravity="center"
                    android:text="@string/title_granary"
                    android:textAppearance="?android:attr/textAppearanceMedium" />

                <TextView
                    android:id="@+id/txtChooseResource"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginLeft="@dimen/MainViewSideMargin"
                    android:layout_marginTop="@dimen/MainViewSpacing"
                    android:layout_marginBottom="@dimen/MainViewSpacing"
                    android:layout_marginRight="@dimen/MainViewSideMargin"
                    android:background="?attr/TextViewBackgroundColour"
                    android:text="@string/processors_choose_type"
                    android:textColor="?attr/InfoColour"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/txtDescGranary"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginLeft="@dimen/MainViewSideMargin"
                    android:layout_marginRight="@dimen/MainViewSideMargin"
                    android:background="?attr/TextViewBackgroundColour"
                    android:text="@string/desc_granary"
                    android:textColor="?attr/InfoColour"
                    android:textStyle="bold" />

                <com.apps.fast.launch.views.PurchaseButton
                    android:id="@+id/btnBuildGranary"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"/>

                <TextView
                    android:id="@+id/txtFoundry"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:layout_marginTop="@dimen/ButtonInset"
                    android:layout_marginBottom="@dimen/ButtonInset"
                    android:gravity="center"
                    android:text="@string/title_foundry"
                    android:textAppearance="?android:attr/textAppearanceMedium" />

                <TextView
                    android:id="@+id/txtDescFoundry"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginLeft="@dimen/MainViewSideMargin"
                    android:layout_marginRight="@dimen/MainViewSideMargin"
                    android:background="?attr/TextViewBackgroundColour"
                    android:text="@string/desc_foundry"
                    android:textColor="?attr/InfoColour"
                    android:textStyle="bold" />

                <com.apps.fast.launch.views.PurchaseButton
                    android:id="@+id/btnBuildFoundry"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"/>

                <TextView
                    android:id="@+id/txtOilRefinery"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:layout_marginTop="@dimen/ButtonInset"
                    android:layout_marginBottom="@dimen/ButtonInset"
                    android:gravity="center"
                    android:text="@string/title_oil_refinery"
                    android:textAppearance="?android:attr/textAppearanceMedium" />

                <TextView
                    android:id="@+id/txtDescOilRefinery"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginLeft="@dimen/MainViewSideMargin"
                    android:layout_marginRight="@dimen/MainViewSideMargin"
                    android:background="?attr/TextViewBackgroundColour"
                    android:text="@string/desc_oil_refinery"
                    android:textColor="?attr/InfoColour"
                    android:textStyle="bold" />

                <com.apps.fast.launch.views.PurchaseButton
                    android:id="@+id/btnBuildOilRefinery"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"/>

                <TextView
                    android:id="@+id/txtConstructionYard"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:layout_marginTop="@dimen/ButtonInset"
                    android:layout_marginBottom="@dimen/ButtonInset"
                    android:gravity="center"
                    android:text="@string/title_construction_yard"
                    android:textAppearance="?android:attr/textAppearanceMedium" />

                <TextView
                    android:id="@+id/txtDescConstructionYard"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginLeft="@dimen/MainViewSideMargin"
                    android:layout_marginRight="@dimen/MainViewSideMargin"
                    android:background="?attr/TextViewBackgroundColour"
                    android:text="@string/desc_construction_yard"
                    android:textColor="?attr/InfoColour"
                    android:textStyle="bold" />

                <com.apps.fast.launch.views.PurchaseButton
                    android:id="@+id/btnBuildConstructionYard"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"/>

                <TextView
                    android:id="@+id/txtExplosivesFactory"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:layout_marginTop="@dimen/ButtonInset"
                    android:layout_marginBottom="@dimen/ButtonInset"
                    android:gravity="center"
                    android:text="@string/title_explosives_factory"
                    android:textAppearance="?android:attr/textAppearanceMedium"
                    android:visibility="gone" />

                <TextView
                    android:id="@+id/txtDescExplosivesFactory"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginLeft="@dimen/MainViewSideMargin"
                    android:layout_marginRight="@dimen/MainViewSideMargin"
                    android:background="?attr/TextViewBackgroundColour"
                    android:text="@string/desc_explosives_factory"
                    android:textColor="?attr/InfoColour"
                    android:textStyle="bold"
                    android:visibility="gone" />

                <com.apps.fast.launch.views.PurchaseButton
                    android:id="@+id/btnBuildExplosivesFactory"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:visibility="gone" />

                <TextView
                    android:id="@+id/txtChemicalPlant"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:layout_marginTop="@dimen/ButtonInset"
                    android:layout_marginBottom="@dimen/ButtonInset"
                    android:gravity="center"
                    android:text="@string/title_chemical_plant"
                    android:textAppearance="?android:attr/textAppearanceMedium" />

                <TextView
                    android:id="@+id/txtDescChemicalPlant"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginLeft="@dimen/MainViewSideMargin"
                    android:layout_marginRight="@dimen/MainViewSideMargin"
                    android:background="?attr/TextViewBackgroundColour"
                    android:text="@string/desc_chemical_plant"
                    android:textColor="?attr/InfoColour"
                    android:textStyle="bold" />

                <com.apps.fast.launch.views.PurchaseButton
                    android:id="@+id/btnBuildChemicalPlant"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"/>

                <TextView
                    android:id="@+id/txtPowerPlant"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:layout_marginTop="@dimen/ButtonInset"
                    android:layout_marginBottom="@dimen/ButtonInset"
                    android:gravity="center"
                    android:text="@string/title_power_plant"
                    android:textAppearance="?android:attr/textAppearanceMedium" />

                <TextView
                    android:id="@+id/txtDescPowerPlant"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginLeft="@dimen/MainViewSideMargin"
                    android:layout_marginRight="@dimen/MainViewSideMargin"
                    android:background="?attr/TextViewBackgroundColour"
                    android:text="@string/desc_power_plant"
                    android:textColor="?attr/InfoColour"
                    android:textStyle="bold" />

                <com.apps.fast.launch.views.PurchaseButton
                    android:id="@+id/btnBuildPowerPlant"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"/>

                <TextView
                    android:id="@+id/txtNuclearPowerPlant"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:layout_marginTop="@dimen/ButtonInset"
                    android:layout_marginBottom="@dimen/ButtonInset"
                    android:gravity="center"
                    android:text="@string/title_nuclear_power_plant"
                    android:textAppearance="?android:attr/textAppearanceMedium" />

                <TextView
                    android:id="@+id/txtDescNuclearPowerPlant"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginLeft="@dimen/MainViewSideMargin"
                    android:layout_marginRight="@dimen/MainViewSideMargin"
                    android:background="?attr/TextViewBackgroundColour"
                    android:text="@string/desc_nuclear_power_plant"
                    android:textColor="?attr/InfoColour"
                    android:textStyle="bold" />

                <com.apps.fast.launch.views.PurchaseButton
                    android:id="@+id/btnBuildNuclearPowerPlant"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"/>

                <TextView
                    android:id="@+id/txtEnrichmentFacility"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:layout_marginTop="@dimen/ButtonInset"
                    android:layout_marginBottom="@dimen/ButtonInset"
                    android:gravity="center"
                    android:text="@string/title_enrichment_facility"
                    android:textAppearance="?android:attr/textAppearanceMedium" />

                <TextView
                    android:id="@+id/txtDescEnrichmentFacility"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginLeft="@dimen/MainViewSideMargin"
                    android:layout_marginRight="@dimen/MainViewSideMargin"
                    android:background="?attr/TextViewBackgroundColour"
                    android:text="@string/desc_enrichment_facility"
                    android:textColor="?attr/InfoColour"
                    android:textStyle="bold" />

                <com.apps.fast.launch.views.PurchaseButton
                    android:id="@+id/btnBuildEnrichmentFacility"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"/>

                <TextView
                    android:id="@+id/txtLaboratory"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:layout_marginTop="@dimen/ButtonInset"
                    android:layout_marginBottom="@dimen/ButtonInset"
                    android:gravity="center"
                    android:text="@string/title_laboratory"
                    android:textAppearance="?android:attr/textAppearanceMedium" />

                <TextView
                    android:id="@+id/txtDescLaboratory"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginLeft="@dimen/MainViewSideMargin"
                    android:layout_marginRight="@dimen/MainViewSideMargin"
                    android:background="?attr/TextViewBackgroundColour"
                    android:text="@string/desc_laboratory"
                    android:textColor="?attr/InfoColour"
                    android:textStyle="bold" />

                <com.apps.fast.launch.views.PurchaseButton
                    android:id="@+id/btnBuildLaboratory"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"/>

                <TextView
                    android:id="@+id/txtMachineShop"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:layout_marginTop="@dimen/ButtonInset"
                    android:layout_marginBottom="@dimen/ButtonInset"
                    android:gravity="center"
                    android:text="@string/title_machine_shop"
                    android:textAppearance="?android:attr/textAppearanceMedium" />

                <TextView
                    android:id="@+id/txtDescMachineShop"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginLeft="@dimen/MainViewSideMargin"
                    android:layout_marginRight="@dimen/MainViewSideMargin"
                    android:background="?attr/TextViewBackgroundColour"
                    android:text="@string/desc_machine_shop"
                    android:textColor="?attr/InfoColour"
                    android:textStyle="bold" />

                <com.apps.fast.launch.views.PurchaseButton
                    android:id="@+id/btnBuildMachineShop"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"/>

                <TextView
                    android:id="@+id/txtLithographyPlant"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:layout_marginTop="@dimen/ButtonInset"
                    android:layout_marginBottom="@dimen/ButtonInset"
                    android:gravity="center"
                    android:text="@string/title_lithography_plant"
                    android:textAppearance="?android:attr/textAppearanceMedium" />

                <TextView
                    android:id="@+id/txtDescLithographyPlant"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginLeft="@dimen/MainViewSideMargin"
                    android:layout_marginRight="@dimen/MainViewSideMargin"
                    android:background="?attr/TextViewBackgroundColour"
                    android:text="@string/desc_lithography_plant"
                    android:textColor="?attr/InfoColour"
                    android:textStyle="bold" />

                <com.apps.fast.launch.views.PurchaseButton
                    android:id="@+id/btnBuildLithographyPlant"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/MainViewSideMargin"
                android:layout_marginBottom="@dimen/MainViewSideMargin"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/btnCancel"
                    android:layout_width="fill_parent"
                    android:layout_height="@dimen/ButtonHeight"
                    android:layout_gravity="center_horizontal"
                    android:layout_marginLeft="@dimen/MainViewSideMargin"
                    android:layout_marginRight="@dimen/MainViewSideMargin"
                    android:layout_weight="1"
                    android:background="@drawable/text_button_normal"
                    android:clickable="true"
                    android:gravity="center"
                    android:text="@string/cancel"
                    android:visibility="visible" />

            </LinearLayout>
        </LinearLayout>
    </ScrollView>