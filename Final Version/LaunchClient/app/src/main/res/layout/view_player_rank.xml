<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
              android:orientation="vertical"
              android:layout_width="fill_parent"
              android:layout_height="wrap_content">

    <LinearLayout
        android:id="@+id/lytBackground"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginTop="@dimen/SelectListSpacing"
        android:background="@drawable/detail_button_disabled"
        android:orientation="vertical">

        <LinearLayout
            android:id="@+id/lyt1"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <ImageView
                android:id="@+id/imgPlayer"
                android:layout_width="@dimen/PlayerInfoIconSize"
                android:layout_height="@dimen/PlayerInfoIconSize"
                android:layout_gravity="center"
                android:layout_margin="@dimen/ButtonEdgePadding"/>

            <LinearLayout
                android:id="@+id/lytText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_gravity="center_vertical"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/txtName"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Name"
                    android:textAppearance="?android:attr/textAppearanceMedium"/>

                <TextView
                    android:id="@+id/txtAlliance"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_horizontal"
                    android:layout_weight="1"
                    android:textStyle="bold"
                    android:text="Alliance"/>

                <TextView
                    android:id="@+id/txtAWOL"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginRight="@dimen/CloseButtonSize"
                    android:text="@string/awol"
                    android:textColor="?attr/BadColour"
                    android:textStyle="bold"
                    android:visibility="gone"/>

                <TextView
                    android:id="@+id/txtMultiplier"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginRight="@dimen/CloseButtonSize"
                    android:text="x1"
                    android:textStyle="bold"/>

            </LinearLayout>

            <ImageView
                android:id="@+id/imgLeader"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_margin="@dimen/ButtonEdgePadding"
                android:src="@drawable/icon_leader" />

            <ImageView
                android:id="@+id/imgAlly"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_margin="@dimen/ButtonEdgePadding"
                android:src="@drawable/icon_ally"/>

            <ImageView
                android:id="@+id/imgWar"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_margin="@dimen/ButtonEdgePadding"
                android:src="@drawable/icon_war"/>

            <ImageView
                android:id="@+id/imgAffiliate"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_margin="@dimen/ButtonEdgePadding"
                android:src="@drawable/icon_affiliate"/>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/lyt2"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_gravity="center_vertical"
            android:orientation="horizontal">

            <LinearLayout
                android:id="@+id/lyt3"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/txtWealthTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginRight="@dimen/SeperatorMargins"
                    android:text="@string/total"/>

                <TextView
                    android:id="@+id/txtWorthTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginRight="@dimen/SeperatorMargins"
                    android:text="@string/worth"/>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/lyt4"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/txtTotal"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="£xxx"
                    android:textColor="?attr/WarningColour" />

                <TextView
                    android:id="@+id/txtEconomicValue"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="£xxx"
                    android:textColor="?attr/WarningColour"/>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/lyt5"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:visibility="visible">

                <TextView
                    android:id="@+id/txtOffencesTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/offences" />

                <TextView
                    android:id="@+id/txtDefencesTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/defences" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/lyt6"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:visibility="visible">

                <TextView
                    android:id="@+id/txtOffences"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="£xxx"
                    android:textColor="?attr/WarningColour" />

                <TextView
                    android:id="@+id/txtDefences"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="£xxx"
                    android:textColor="?attr/WarningColour" />
            </LinearLayout>

        </LinearLayout>

        <LinearLayout
            android:id="@+id/lytStats"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="visible">

            <LinearLayout
                android:id="@+id/lytCities"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/txtCitiesTitle"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/city_count" />

                <TextView
                    android:id="@+id/txtCities"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="0"
                    android:textColor="?attr/WarningColour" />

            </LinearLayout>

            <LinearLayout
                android:id="@+id/lytRank"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/txtRankTitle"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/rank_title" />

                <TextView
                    android:id="@+id/txtRankName"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="0"
                    android:textColor="?attr/WarningColour" />

            </LinearLayout>

            <LinearLayout
                android:id="@+id/lytWins"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/txtWinsTitle"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/win_title" />

                <TextView
                    android:id="@+id/txtWinsName"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="0"
                    android:textColor="?attr/WarningColour" />

            </LinearLayout>

            <LinearLayout
                android:id="@+id/lytExperience"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/txtExperienceTitle"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/experience_title" />

                <TextView
                    android:id="@+id/txtExperience"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="0"
                    android:textColor="?attr/WarningColour" />

            </LinearLayout>

            <LinearLayout
                android:id="@+id/lytTotalKills"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/txtTotalKillsTitle"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/total_kills" />

                <TextView
                    android:id="@+id/txtTotalKillsTotal"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="0"
                    android:textColor="?attr/WarningColour" />

            </LinearLayout>

            <LinearLayout
                android:id="@+id/lytTotalDeaths"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/txtTotalDeathsTitle"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/total_deaths" />

                <TextView
                    android:id="@+id/txtTotalDeathsTotal"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="0"
                    android:textColor="?attr/WarningColour" />

            </LinearLayout>

            <LinearLayout
                android:id="@+id/lytKDR"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/txtKDRTitle"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/kills_deaths_ratio" />

                <TextView
                    android:id="@+id/txtKDRTotal"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="0"
                    android:textColor="?attr/WarningColour" />

            </LinearLayout>

            <LinearLayout
                android:id="@+id/lytDamageInflicted"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/txtDamageInflictedTitle"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="2"
                    android:text="@string/damage_inflicted" />

                <TextView
                    android:id="@+id/txtDamageInflictedTotal"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="0hp"
                    android:textColor="?attr/WarningColour" />

                <TextView
                    android:id="@+id/txtOffenceSpendingCost"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="£0"
                    android:textColor="?attr/WarningColour" />


            </LinearLayout>

            <LinearLayout
                android:id="@+id/lytDamageReceived"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/txtDamageReceivedTitle"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="2"
                    android:text="@string/damage_received" />

                <TextView
                    android:id="@+id/txtDamageReceivedTotal"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="0hp"
                    android:textColor="?attr/WarningColour" />

                <TextView
                    android:id="@+id/txtDefenceSpendingCost"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="£0"
                    android:textColor="?attr/WarningColour" />

            </LinearLayout>
        </LinearLayout>

    </LinearLayout>

</LinearLayout>